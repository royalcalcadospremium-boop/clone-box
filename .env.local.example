# =============================================================
# CloneBox â€” Template de variĂˇveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais
# NUNCA commitar o .env.local real
# =============================================================

# =============================================================
# APP
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CloneBox

# =============================================================
# SUPABASE
# =============================================================
# Obtido em: supabase.com â†’ Settings â†’ API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role: APENAS server-side, NUNCA expor no cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# String de conexĂŁo direta (para Drizzle)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================
# KIMI API (Moonshot AI)
# =============================================================
# Obtido em: platform.moonshot.ai â†’ API Keys
KIMI_API_KEY=sk-...

# =============================================================
# BYTEPLUS MODELARK (Seedance + Nano Banana)
# =============================================================
# Obtido em: console.byteplus.com â†’ ModelArk â†’ API Keys
BYTEPLUS_API_KEY=your_byteplus_api_key
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# IDs dos modelos (confirmar na documentaĂ§ĂŁo BytePlus)
BYTEPLUS_SEEDANCE_MODEL_ID=seedance-2-0-fast
BYTEPLUS_NANO_BANANA_MODEL_ID=nano-banana-2

# =============================================================
# FAL.AI (Whisper transcriĂ§ĂŁo)
# =============================================================
# Obtido em: fal.ai â†’ Account â†’ API Keys
FAL_KEY=your_fal_api_key

# =============================================================
# UPSTASH REDIS (Rate Limiting)
# =============================================================
# Obtido em: console.upstash.com â†’ Redis â†’ Connect
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# =============================================================
# INNGEST (Jobs AssĂ­ncronos)
# =============================================================
# Obtido em: app.inngest.com â†’ Settings
INNGEST_EVENT_KEY=inngest_event_key_...
INNGEST_SIGNING_KEY=signkey-prod-...

# =============================================================
# STRIPE (Pagamentos internacionais â€” cartĂŁo)
# =============================================================
# Obtido em: dashboard.stripe.com â†’ Developers â†’ API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs dos produtos/preĂ§os criados no Stripe
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Pacotes avulsos
STRIPE_PRICE_TOPUP_MINI=price_...
STRIPE_PRICE_TOPUP_MEDIO=price_...
STRIPE_PRICE_TOPUP_GRANDE=price_...
STRIPE_PRICE_TOPUP_JUMBO=price_...
STRIPE_PRICE_TOPUP_ENTERPRISE=price_...

# =============================================================
# PAGAR.ME (Pagamentos BR â€” PIX, boleto, cartĂŁo nacional)
# =============================================================
# Obtido em: dashboard.pagar.me
PAGARME_API_KEY=ak_live_...
PAGARME_WEBHOOK_SECRET=your_pagarme_webhook_secret

# =============================================================
# CLOUDFLARE R2 (Storage de vĂ­deos gerados)
# =============================================================
# Obtido em: dash.cloudflare.com â†’ R2 â†’ Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET_NAME=clonebox-videos
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# =============================================================
# RESEND (Emails transacionais)
# =============================================================
# Obtido em: resend.com â†’ API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@clonebox.com.br

# =============================================================
# SENTRY (Error Tracking)
# =============================================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================
# POSTHOG (Analytics de produto)
# =============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================
# TAXA DE CĂ‚MBIO (Para cĂˇlculo de custo em BRL)
# =============================================================
# Atualizar manualmente ou via cron com API de cĂ˘mbio
USD_TO_BRL_RATE=6.10


# =============================================================
# INTEGRAÇŐES E-COMMERCE (OAuth 2.0)
# =============================================================

# NUVEMSHOP
# Obtido em: partners.nuvemshop.com.br -> Criar App
NUVEMSHOP_APP_ID=your_nuvemshop_app_id
NUVEMSHOP_APP_SECRET=your_nuvemshop_app_secret

# SHOPIFY
# Obtido em: partners.shopify.com -> Criar App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# MERCADO LIVRE
# Obtido em: developers.mercadolibre.com.br -> Criar App
MERCADOLIVRE_APP_ID=your_ml_app_id
MERCADOLIVRE_APP_SECRET=your_ml_app_secret

# SHOPEE
# Obtido em: open.shopee.com -> Registrar como Partner
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_key

# TIKTOK SHOP
# Obtido em: partner.tiktokshop.com -> Criar App
TIKTOKSHOP_APP_KEY=your_tiktok_app_key
TIKTOKSHOP_APP_SECRET=your_tiktok_app_secret
