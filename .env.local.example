# =============================================================
# CloneBox — Template de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais
# NUNCA commitar o .env.local real
# =============================================================

# =============================================================
# APP
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CloneBox

# =============================================================
# SUPABASE
# =============================================================
# Obtido em: supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role: APENAS server-side, NUNCA expor no cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# String de conexão direta (para Drizzle)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================
# ANTHROPIC (Claude)
# =============================================================
# Obtido em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# =============================================================
# BYTEPLUS MODELARK (Seedance + Nano Banana)
# =============================================================
# Obtido em: console.byteplus.com → ModelArk → API Keys
BYTEPLUS_API_KEY=your_byteplus_api_key
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# IDs dos modelos (confirmar na documentação BytePlus)
BYTEPLUS_SEEDANCE_MODEL_ID=seedance-2-0-fast
BYTEPLUS_NANO_BANANA_MODEL_ID=nano-banana-2

# =============================================================
# FAL.AI (Whisper transcrição)
# =============================================================
# Obtido em: fal.ai → Account → API Keys
FAL_KEY=your_fal_api_key

# =============================================================
# UPSTASH REDIS (Rate Limiting)
# =============================================================
# Obtido em: console.upstash.com → Redis → Connect
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# =============================================================
# INNGEST (Jobs Assíncronos)
# =============================================================
# Obtido em: app.inngest.com → Settings
INNGEST_EVENT_KEY=inngest_event_key_...
INNGEST_SIGNING_KEY=signkey-prod-...

# =============================================================
# STRIPE (Pagamentos internacionais — cartão)
# =============================================================
# Obtido em: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs dos produtos/preços criados no Stripe
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Pacotes avulsos
STRIPE_PRICE_TOPUP_MINI=price_...
STRIPE_PRICE_TOPUP_MEDIO=price_...
STRIPE_PRICE_TOPUP_GRANDE=price_...
STRIPE_PRICE_TOPUP_JUMBO=price_...
STRIPE_PRICE_TOPUP_ENTERPRISE=price_...

# =============================================================
# PAGAR.ME (Pagamentos BR — PIX, boleto, cartão nacional)
# =============================================================
# Obtido em: dashboard.pagar.me
PAGARME_API_KEY=ak_live_...
PAGARME_WEBHOOK_SECRET=your_pagarme_webhook_secret

# =============================================================
# CLOUDFLARE R2 (Storage de vídeos gerados)
# =============================================================
# Obtido em: dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET_NAME=clonebox-videos
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# =============================================================
# RESEND (Emails transacionais)
# =============================================================
# Obtido em: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@clonebox.com.br

# =============================================================
# SENTRY (Error Tracking)
# =============================================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================
# POSTHOG (Analytics de produto)
# =============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================
# TAXA DE CÂMBIO (Para cálculo de custo em BRL)
# =============================================================
# Atualizar manualmente ou via cron com API de câmbio
USD_TO_BRL_RATE=6.10
