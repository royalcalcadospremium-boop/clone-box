# ============================================================
# HIGGSFIELD CLONE — API KEYS
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# --- FAL.ai (Flux, WAN 2.6, Nano Banana, etc.) ---
# Signup: https://fal.ai/dashboard/login
FAL_KEY=

# --- Black Forest Labs (Flux 2 / FLUX Pro) ---
# Signup: https://bfl.ai/models/flux-kontext-pro
BFL_API_KEY=

# --- OpenAI (GPT Image 2, Sora 2, ChatGPT 4o/5) ---
# Signup: https://platform.openai.com/signup
OPENAI_API_KEY=

# --- Kling AI (Kling 3.0 video) ---
# Signup: https://klingai.com/global/dev/
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- BytePlus / Seedance (Seedance 2.0 video) ---
# Signup: https://www.byteplus.com/en
BYTEPLUS_API_KEY=

# --- MiniMax (Hailuo video) ---
# Signup: https://platform.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# --- ElevenLabs (Áudio / Voiceover / Translate) ---
# Signup: https://elevenlabs.io/app/sign-up
ELEVENLABS_API_KEY=

# --- Configurações internas ---
# Chave secreta para validar requests internos
INTERNAL_API_SECRET=mude-esta-chave-para-algo-seguro

# --- Créditos por operação (em centavos de crédito) ---
# Você pode ajustar estes valores para controlar sua margem
CREDITS_IMAGE_STANDARD=2
CREDITS_IMAGE_PREMIUM=5
CREDITS_VIDEO_5S=60
CREDITS_VIDEO_10S=100
CREDITS_AUDIO_PER_1K_CHARS=10
CREDITS_CHAT_PER_MSG=1
